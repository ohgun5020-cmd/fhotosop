{
  "id": "com.makeit.psd-stitcher",
  "name": "fhotoshop",
  "version": "1.0.1",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "PS",
    "minVersion": "27.6.0"
  },
  "requiredPermissions": {
    "localFileSystem": "request",
    "network": {
      "domains": [
        "https://api.openai.com",
        "https://generativelanguage.googleapis.com"
      ]
    },
    "allowCodeGenerationFromStrings": true
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "stitcher",
      "label": {
        "default": "fhotoshop"
      },
      "minimumSize": {
        "width": 320,
        "height": 360
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 520
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 620
      }
    }
  ]
}
